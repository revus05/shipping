generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  WORKER
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ContainerType {
  TWENTY_FT
  FORTY_FT
  FORTY_HC
}

enum ContainerStatus {
  AVAILABLE
  ASSIGNED
  IN_TRANSIT
  DELIVERED
}

enum PIStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum CIStatus {
  DRAFT
  ISSUED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(WORKER)
  createdAt    DateTime @default(now())

  @@map("users")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  address   String?
  contact   String?
  email     String?
  phone     String?
  country   String?
  createdAt DateTime @default(now())

  products Product[]
  orders   Order[]

  @@map("suppliers")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  address   String?
  contact   String?
  email     String?
  phone     String?
  country   String?
  createdAt DateTime @default(now())

  orders Order[]

  @@map("customers")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  description String?
  unit        String
  unitPrice   Decimal  @db.Decimal(12, 4)
  currency    String   @default("USD")
  supplierId  String
  createdAt   DateTime @default(now())

  supplier   Supplier    @relation(fields: [supplierId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  status      OrderStatus @default(DRAFT)
  customerId  String
  supplierId  String
  notes       String?
  createdAt   DateTime    @default(now())

  customer           Customer           @relation(fields: [customerId], references: [id])
  supplier           Supplier           @relation(fields: [supplierId], references: [id])
  items              OrderItem[]
  containers         Container[]
  proformaInvoices   ProformaInvoice[]
  commercialInvoices CommercialInvoice[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Decimal @db.Decimal(12, 4)
  unitPrice Decimal @db.Decimal(12, 4)
  currency  String  @default("USD")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Container {
  id              String          @id @default(cuid())
  containerNumber String          @unique
  type            ContainerType
  status          ContainerStatus @default(AVAILABLE)
  orderId         String?
  createdAt       DateTime        @default(now())

  order Order? @relation(fields: [orderId], references: [id])

  @@map("containers")
}

model ProformaInvoice {
  id         String   @id @default(cuid())
  piNumber   String   @unique
  orderId    String
  status     PIStatus @default(DRAFT)
  issuedDate DateTime
  validUntil DateTime
  notes      String?
  createdAt  DateTime @default(now())

  order             Order              @relation(fields: [orderId], references: [id])
  commercialInvoice CommercialInvoice?

  @@map("proforma_invoices")
}

model CommercialInvoice {
  id              String   @id @default(cuid())
  ciNumber        String   @unique
  orderId         String
  piId            String?  @unique
  status          CIStatus @default(DRAFT)
  issuedDate      DateTime
  paymentTerms    String?
  portOfLoading   String?
  portOfDischarge String?
  notes           String?
  createdAt       DateTime @default(now())

  order           Order            @relation(fields: [orderId], references: [id])
  proformaInvoice ProformaInvoice? @relation(fields: [piId], references: [id])

  @@map("commercial_invoices")
}
